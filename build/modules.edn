{:project
 {:url         "https://github.com/velio-io/collet"
  :license     {:name "Apache License, Version 2.0"
                :url  "https://www.apache.org/licenses/LICENSE-2.0.txt"}
  :scm         {:url                  "https://github.com/velio-io/collet"
                :connection           "scm:git:https://github.com/velio-io/collet.git"
                :developer-connection "scm:git:ssh://git@github.com/velio-io/collet.git"
                :tag                  "HEAD"}
  :jvm-opts    ["--add-exports=java.base/jdk.internal.ref=ALL-UNNAMED"
                "--add-exports=java.base/sun.nio.ch=ALL-UNNAMED"
                "--add-exports=jdk.unsupported/sun.misc=ALL-UNNAMED"
                "--add-exports=jdk.compiler/com.sun.tools.javac.file=ALL-UNNAMED"
                "--add-opens=jdk.compiler/com.sun.tools.javac=ALL-UNNAMED"
                "--add-opens=java.base/java.lang=ALL-UNNAMED"
                "--add-opens=java.base/java.lang.reflect=ALL-UNNAMED"
                "--add-opens=java.base/java.io=ALL-UNNAMED"
                "--add-opens=java.base/java.util=ALL-UNNAMED"
                "--add-opens=java.base/java.nio=org.apache.arrow.memory.core,ALL-UNNAMED"
                "--enable-native-access=ALL-UNNAMED"]}

 :module-order
 [:collet-core
  :collet-action-http
  :collet-action-file
  :collet-action-odata
  :collet-action-jdbc
  :collet-action-s3
  :collet-action-queue
  :collet-action-jslt
  :collet-action-llm
  :collet-action-vega
  :collet-action-lucene
  :collet-actions
  :collet-app
  :collet-cli]

 :modules
 {:collet-core
  {:lib           io.velio/collet-core
   :version       "0.2.8-SNAPSHOT"
   :description   "Collet workflow engine core"
   :dir           "collet-core"
   :source-dirs   ["src"]
   :resource-dirs ["resources"]
   :internal-deps []}

  :collet-action-http
  {:lib io.velio/collet-action-http, :version "0.2.8-SNAPSHOT"
   :description "HTTP actions for Collet", :dir "collet-action-http"
   :internal-deps [:collet-core]}
  :collet-action-file
  {:lib io.velio/collet-action-file, :version "0.2.8-SNAPSHOT"
   :description "File actions for Collet", :dir "collet-action-file"
   :internal-deps [:collet-core :collet-action-http]}
  :collet-action-odata
  {:lib io.velio/collet-action-odata, :version "0.2.8-SNAPSHOT"
   :description "OData actions for Collet", :dir "collet-action-odata"
   :internal-deps [:collet-core :collet-action-http]}
  :collet-action-jdbc
  {:lib io.velio/collet-action-jdbc, :version "0.2.8-SNAPSHOT"
   :description "JDBC actions for Collet", :dir "collet-action-jdbc"
   :internal-deps [:collet-core]}
  :collet-action-s3
  {:lib io.velio/collet-action-s3, :version "0.2.8-SNAPSHOT"
   :description "S3 actions for Collet", :dir "collet-action-s3"
   :internal-deps [:collet-core :collet-action-file]}
  :collet-action-queue
  {:lib io.velio/collet-action-queue, :version "0.2.8-SNAPSHOT"
   :description "Queue actions for Collet", :dir "collet-action-queue"
   :internal-deps [:collet-core]}
  :collet-action-jslt
  {:lib io.velio/collet-action-jslt, :version "0.2.8-SNAPSHOT"
   :description "JSLT actions for Collet", :dir "collet-action-jslt"
   :internal-deps [:collet-core]}
  :collet-action-llm
  {:lib io.velio/collet-action-llm, :version "0.2.8-SNAPSHOT"
   :description "LLM actions for Collet", :dir "collet-action-llm"
   :internal-deps [:collet-core]}
  :collet-action-vega
  {:lib io.velio/collet-action-vega, :version "0.2.8-SNAPSHOT"
   :description "Vega rendering actions for Collet", :dir "collet-action-vega"
   :internal-deps [:collet-core :collet-action-file]}
  :collet-action-lucene
  {:lib io.velio/collet-action-lucene, :version "0.2.8-SNAPSHOT"
   :description "Lucene actions for Collet", :dir "collet-action-lucene"
   :internal-deps [:collet-core]}
  :collet-actions
  {:lib io.velio/collet-actions, :version "0.2.8-SNAPSHOT"
   :description "Compatibility aggregate for all Collet actions"
   :dir "collet-actions"
   :source-dirs []
   :resource-dirs []
   :internal-deps [:collet-action-http :collet-action-file :collet-action-odata
                   :collet-action-jdbc :collet-action-s3 :collet-action-queue
                   :collet-action-jslt :collet-action-llm :collet-action-vega
                   :collet-action-lucene]}
  :collet-app
  {:lib io.velio/collet-app, :version "0.2.8-SNAPSHOT"
   :description "Standalone Collet application", :dir "collet-app"
   :internal-deps [:collet-core]
   :main collet.main
   :uber-file "target/collet.jar"}
  :collet-cli
  {:lib io.velio/collet-cli, :version "0.2.8-SNAPSHOT"
   :description "CLI interface for Collet", :dir "collet-cli"
   :internal-deps [:collet-app]
   :main pod.collet.core
   :uber-file "target/collet.pod.jar"
   :publish? false}}}
